<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/sp_panel_background">

    <TextView
        android:id="@+id/textType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/sp_text_primary" />

    <TextView
        android:id="@+id/textDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/sp_text_secondary" />

    <TextView
        android:id="@+id/textCreator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/sp_text_primary" />

    <TextView
        android:id="@+id/textPhone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/sp_text_primary" />

    <TextView
        android:id="@+id/textCoords"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/sp_text_secondary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textHeartRate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Heart Rate: -"
            android:textColor="@color/sp_text_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textOxygen"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SpO2: -"
            android:textColor="@color/sp_text_primary"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/textBiometricTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/sp_text_secondary"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/textMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="@color/sp_text_primary" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNavigate"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/sp_button_sos"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="Πλοήγηση στο συμβάν"
        android:textColor="@android:color/white"
        android:textStyle="bold" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNearestAed"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/sp_button_primary"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="Κοντινότερος απινιδωτής"
        android:textColor="@android:color/white"
        android:textStyle="bold" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCopy"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/sp_button_primary"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="Αντιγραφή συντεταγμένων"
        android:textColor="@android:color/white"
        android:textStyle="bold" />

</LinearLayout>